# Málaga Startup Network — bloquear fuentes y enrutar SPA
RewriteEngine On
RewriteRule ^project/ - [F,L]
RewriteRule ^(src|supabase|node_modules)/ - [F,L]
<IfModule mod_rewrite.c>
  RewriteBase /
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  RewriteRule ^ index.html [L]
</IfModule>
